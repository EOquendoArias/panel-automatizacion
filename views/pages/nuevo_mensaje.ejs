<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">

<style>
    .whatsapp-preview {
        background-color: #e5ddd5;
        background-image: url('https://user-images.githubusercontent.com/15075759/28719144-86dc0f70-73b1-11e7-911d-60d70fcded21.png');
        padding: 15px; border-radius: 10px; min-height: 100px;
    }
    .whatsapp-bubble {
        background: white; padding: 10px; border-radius: 7px;
        box-shadow: 0 1px 0.5px rgba(0,0,0,0.13); font-size: 14px;
        white-space: pre-wrap; word-wrap: break-word;
    }
    .grupo-lista {
        max-height: 200px; overflow-y: auto;
        border: 1px solid #ddd; padding: 10px; border-radius: 5px; background: #fff;
    }
    .grupo-item { display: block; margin-bottom: 5px; cursor: pointer; }
</style>

<div class="container-fluid">
    <form action="/guardar_mensaje" method="POST" enctype="multipart/form-data" id="formNuevo">
        <div class="row">
            <div class="col-md-7">
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <h5 class="card-title mb-3">✍️ Redactar Mensaje</h5>
                        <div id="editor" style="height:250px;"></div>
                        <input type="hidden" name="texto" id="texto">

                        <h6 class="mt-4">📱 Vista previa</h6>
                        <div class="whatsapp-preview">
                            <div class="whatsapp-bubble" id="preview-text">Escribe algo...</div>
                            <div id="preview-container" class="mt-2" style="display:none;">
                                <img id="preview-img" style="max-width:100%; border-radius:6px; display:none;">
                                <video id="preview-video" controls style="max-width:100%; border-radius:6px; display:none;"></video>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <h5 class="card-title mb-3">⚙️ Configuración</h5>

                        <label class="fw-bold">📡 Plataformas</label>
                        <div class="mb-3">
                            <label class="me-3"><input type="checkbox" name="plataforma" value="whatsapp" checked> WhatsApp</label>
                            <label><input type="checkbox" name="plataforma" value="facebook"> Facebook</label>
                        </div>

                        <label class="fw-bold">📎 Adjuntar Archivo</label>
                        <input type="file" name="archivo" id="archivo" class="form-control mb-2" accept="image/*,video/*">
                        <p class="small text-muted mb-3">Máximo 50MB permitidos.</p>

                        <label class="fw-bold">👥 Grupos de WhatsApp</label>
                        <div class="grupo-lista mb-3">
                            <% grupos.forEach(function(g){ %>
                                <label class="grupo-item small">
                                    <input type="checkbox" name="grupos" value="<%= g.chat_id %>"> <%= g.nombre %>
                                </label>
                            <% }) %>
                        </div>

                        <div class="row">
                            <div class="col-6">
                                <label class="fw-bold">📅 Fecha</label>
<input type="date" name="fecha" value="<%= fechaPrevia %>" class="form-control" required>
                            </div>
                            <div class="col-6">
                                <label class="fw-bold">⏰ Hora</label>
                                <input type="time" name="hora" class="form-control" required>
                            </div>
                        </div>

                        <hr>
                        <button type="submit" class="btn btn-primary w-100 btn-lg shadow">Guardar y Programar</button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
<script>
    // Configuración Editor
    var quill = new Quill('#editor', {
        theme: 'snow',
        modules: { toolbar: [['bold', 'italic', 'strike'], [{ 'list': 'ordered'}, { 'list': 'bullet'}]] }
    });

    // Vista Previa Texto
    quill.on('text-change', function() {
        document.getElementById("preview-text").innerHTML = quill.root.innerHTML || "Escribe algo...";
    });

    // Vista Previa Multimedia
    const archivoInput = document.getElementById("archivo");
    const previewImg = document.getElementById("preview-img");
    const previewVideo = document.getElementById("preview-video");
    const previewContainer = document.getElementById("preview-container");

    archivoInput.addEventListener("change", function(){
        const file = this.files[0];
        if(!file) { previewContainer.style.display = "none"; return; }
        
        if(file.size > 50 * 1024 * 1024) {
            alert("Archivo demasiado grande (Máx 50MB)");
            this.value = ""; return;
        }

        const url = URL.createObjectURL(file);
        previewContainer.style.display = "block";
        previewImg.style.display = file.type.startsWith("image/") ? "block" : "none";
        previewVideo.style.display = file.type.startsWith("video/") ? "block" : "none";
        if(file.type.startsWith("image/")) previewImg.src = url;
        else if(file.type.startsWith("video/")) previewVideo.src = url;
    });

    // Enviar datos
    document.getElementById("formNuevo").onsubmit = function() {
        document.getElementById("texto").value = quill.root.innerHTML;
    };
</script>
