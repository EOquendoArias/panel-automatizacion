<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    .table-img-preview { width: 40px; height: 40px; object-fit: cover; border-radius: 4px; }
    .plataforma-icon { font-size: 1.2rem; }
    .text-truncate-custom {
        max-width: 300px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
</style>

<div class="card shadow-sm">
    <div class="card-header bg-white py-3">
        <h5 class="mb-0 text-primary fw-bold">📜 Historial de envíos</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">ID</th>
                        <th>Plataformas</th>
                        <th>Mensaje</th>
                        <th>Programación</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    <% mensajes.forEach(function(m){ %>
                        <tr>
                            <td class="ps-3 fw-bold">#<%= m.id %></td>
                            <td>
                                <div class="d-flex gap-2">
                                    <% let plats = (m.plataforma || 'whatsapp').split(','); %>
                                    <% if(plats.includes('whatsapp')) { %>
                                        <i class="bi bi-whatsapp text-success plataforma-icon" title="WhatsApp"></i>
                                    <% } %>
                                    <% if(plats.includes('facebook')) { %>
                                        <i class="bi bi-facebook text-primary plataforma-icon" title="Facebook"></i>
                                    <% } %>
                                </div>
                            </td>
                            <td>
                                <div class="text-truncate-custom">
                                    <%= m.texto.replace(/<[^>]+>/g, '').substring(0, 80) %>...
                                </div>
                            </td>
                            <td>
                                <div class="small">
                                    <span class="d-block text-dark fw-bold"><%= m.fecha %></span>
                                    <span class="text-muted"><%= m.hora %></span>
                                </div>
                            </td>
                            <td>
                                <span class="badge rounded-pill bg-success-subtle text-success border border-success">
                                    Enviado
                                </span>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>
