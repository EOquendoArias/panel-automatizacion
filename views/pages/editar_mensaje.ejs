<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">

<div class="container-fluid p-0">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 text-primary">📝 Editando Mensaje #<%= mensaje.id %></h5>
        </div>
        <div class="card-body">
            <form action="/mensajes/actualizar/<%= mensaje.id %>" method="POST" id="formEditar">
                <div class="row">
                    <div class="col-md-8">
                        <label class="fw-bold mb-2">Contenido del Mensaje</label>
                        <div id="editor" style="height: 350px; background: white;">
                            <%- mensaje.texto %>
                        </div>
                        <input type="hidden" name="texto" id="inputTexto">
                    </div>

                    <div class="col-md-4">
                        <div class="p-3 bg-light border rounded mb-3">
                            <label class="fw-bold mb-2">📡 Plataformas</label>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="plataforma" value="whatsapp" <%= mensaje.plataforma.includes('whatsapp') ? 'checked' : '' %>>
                                <label class="form-check-label">WhatsApp</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="plataforma" value="facebook" <%= mensaje.plataforma.includes('facebook') ? 'checked' : '' %>>
                                <label class="form-check-label">Facebook</label>
                            </div>
                        </div>

                        <div class="p-3 bg-light border rounded mb-3">
                            <label class="fw-bold mb-2">👥 Grupos (IDs)</label>
                            <input type="text" name="grupos" class="form-control" value="<%= mensaje.grupos %>">
                        </div>

                        <div class="row p-3">
                            <div class="col-6 p-1">
                                <label class="small fw-bold">Fecha</label>
                                <input type="date" name="fecha" class="form-control" value="<%= mensaje.fecha %>">
                            </div>
                            <div class="col-6 p-1">
                                <label class="small fw-bold">Hora</label>
                                <input type="time" name="hora" class="form-control" value="<%= mensaje.hora %>">
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg">Guardar Cambios</button>
                            <a href="/programados" class="btn btn-light text-muted">Volver</a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
<script>
    var quill = new Quill('#editor', { theme: 'snow', modules: { toolbar: [['bold', 'italic', 'underline'], [{ 'list': 'ordered'}, { 'list': 'bullet' }], ['link', 'clean']] } });
    document.getElementById('formEditar').onsubmit = function() {
        document.getElementById('inputTexto').value = quill.root.innerHTML;
    };
</script>
