<h2>Usuarios</h2>

<div style="margin-bottom:15px;">
<a href="/usuarios/nuevo" class="btn">
➕ Nuevo usuario
</a>
</div>

<table>

<tr>
<th>ID</th>
<th>Nombre</th>
<th>Email</th>
<th>Rol</th>
</tr>

<% usuarios.forEach(function(u){ %>

<tr>

<td><%= u.id %></td>

<td><%= u.nombre %></td>

<td><%= u.email %></td>

<td>

<form action="/usuarios/cambiar-rol/<%= u.id %>" method="POST">

<select name="rol" onchange="this.form.submit()">

<option value="viewer" <%= u.rol=="viewer"?"selected":"" %>>
viewer
</option>

<option value="admin" <%= u.rol=="admin"?"selected":"" %>>
admin
</option>

</select>

</form>

</td>

</tr>

<% }) %>

</table>
