<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<style>
    .calendar-container { background: white; border-radius: 12px; padding: 20px; }
    .calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; background: #dee2e6; border: 1px solid #dee2e6; border-radius: 8px; overflow: hidden; }
    .calendar-header { background: #f8f9fa; font-weight: bold; text-align: center; padding: 10px; border-bottom: 2px solid #dee2e6; }
    .calendar-day { background: white; min-height: 120px; padding: 8px; position: relative; }
    .day-number { 
        font-weight: bold; color: #495057; margin-bottom: 5px; display: inline-block; 
        padding: 2px 6px; border-radius: 4px; transition: 0.2s;
    }
    .day-number:hover { background: #007bff; color: white; cursor: pointer; }
    .day-today { background: #e7f5ff !important; }
.msg-item { 
    font-size: 0.75rem; 
    padding: 4px 8px; 
    border-radius: 6px; 
    margin-bottom: 4px;
    display: flex; 
    align-items: center; 
    justify-content: space-between; /* Esto empuja los iconos a la derecha */
    text-decoration: none; 
    border-left: 4px solid;
    transition: transform 0.1s;
}
.msg-item:hover { transform: scale(1.02); }
.icon-container { display: flex; gap: 4px; font-size: 0.85rem; }
    .msg-pending { background: #e7f5ff; color: #1971c2; border-color: #1971c2; }
    .msg-sent { background: #ebfbee; color: #2b8a3e; border-color: #2b8a3e; }
    .other-month { background: #f8f9fa; color: #adb5bd; }
    .icon-box { display: flex; gap: 3px; font-size: 0.8rem; }
</style>

<div class="calendar-container shadow-sm">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0 text-primary">📅 <%= nombreMes %> <%= anio %></h3>
        <div class="btn-group">
            <a href="/calendario?mes=<%= mes - 1 %>&anio=<%= anio %>" class="btn btn-outline-primary btn-sm">Anterior</a>
            <a href="/calendario" class="btn btn-outline-secondary btn-sm">Hoy</a>
            <a href="/calendario?mes=<%= mes + 1 %>&anio=<%= anio %>" class="btn btn-outline-primary btn-sm">Siguiente</a>
        </div>
    </div>

    <div class="calendar-grid">
        <% ['Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb', 'Dom'].forEach(dia => { %>
            <div class="calendar-header text-muted small"><%= dia %></div>
        <% }) %>

        <% 
            let primerDia = new Date(anio, mes - 1, 1).getDay();
            let ajusteInicio = (primerDia === 0) ? 6 : primerDia - 1;
            let diasEnMes = new Date(anio, mes, 0).getDate();
            let hoyStr = new Date().toISOString().split('T')[0];

            for(let i=0; i < ajusteInicio; i++) { %>
                <div class="calendar-day other-month"></div>
            <% } 

            for(let d=1; d <= diasEnMes; d++) { 
                let dF = d < 10 ? '0' + d : d;
                let mF = mes < 10 ? '0' + mes : mes;
                let fechaActual = `${anio}-${mF}-${dF}`;
                let esHoy = fechaActual === hoyStr;
                let mensajesHoy = mensajes.filter(m => m.fecha === fechaActual);
        %>
            <div class="calendar-day <%= esHoy ? 'day-today' : '' %>">
                <a href="/nuevo_mensaje?fecha=<%= fechaActual %>" class="day-number text-decoration-none" title="Programar para este día">
                    <%= d %>
                </a>
                
                <div class="mt-1">
                    
<% mensajesHoy.forEach(m => { %>
    <% 
        let p = (m.plataforma || 'whatsapp').split(','); 
        let destino = (m.estado === 'enviado') ? '/historial' : '/mensajes/editar/' + m.id;
    %>
    
    <a href="<%= destino %>" class="msg-item <%= m.estado === 'enviado' ? 'msg-sent' : 'msg-pending' %>" title="Ver detalle del mensaje #<%= m.id %>">
        <div class="d-flex flex-column">
            <span class="fw-bold">#<%= m.id %></span>
            <span style="opacity: 0.8;"><%= m.hora %></span>
        </div>
        
        <div class="icon-container">
            <% if(p.includes('whatsapp')){ %>
                <i class="bi bi-whatsapp" style="color: #25D366;"></i>
            <% } %>
            <% if(p.includes('facebook')){ %>
                <i class="bi bi-facebook" style="color: #1877F2;"></i>
            <% } %>
        </div>
    </a>
<% }) %>
                </div>
            </div>
        <% } %>
    </div>
</div>
